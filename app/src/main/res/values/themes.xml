<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Notesapp" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@color/window_bg</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!--
            Platform SplashScreen (minSdk 31): a warm neutral that reads acceptably in
            both light and dark Aura themes, so the cold-start icon screen never flashes
            hard against the resolved theme. The app window itself is repainted with the
            persisted per-user theme colour in MainActivity.onCreate (see BootColors).
            Deprecated statusBarColor/navigationBarColor removed — ignored on Android 15+
            under enforced edge-to-edge (platform.md §5).
        -->
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
    </style>
</resources>
